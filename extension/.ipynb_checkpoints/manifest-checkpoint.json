{
  "manifest_version": 3,
  "name": "Deceptive Review Detector",
  "version": "1.0",
  "description": "Detects fake and AI-generated reviews on Amazon product pages.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*", "*://*.amazon.com/*", "*://*.amazon.in/*"],
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*" , "*://*.amazon.in/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Deceptive Review Detector"
  }
}